const mongoose = require('mongoose');

const ReadingSchema = new mongoose.Schema({
    // بيانات الاتصال
    is_connected: {
        type: Boolean,
        required: true
    },
    latency_ms: {
        type: Number,
        required: true
    },
    // بيانات الشبكة
    network_stats: {
        bytes_sent: Number,
        bytes_recv: Number
    },
    // بيانات الـ Failover
    failover: {
        is_using_backup: Boolean,
        failure_count: Number,
        active_connections: [String]
    },
    // وقت الإرسال
    timestamp: {
        type: Date,
        default: Date.now
    }
});

module.exports = mongoose.model('Reading', ReadingSchema);